          "text": "import java.util.*;\n\nclass Solution {\n    public List<Integer> rollingMax(List<Integer> numbers) {\n        int n = numbers.size();\n        List<Integer> result = new ArrayList<>(n);\n        if (n == 0) return result;\n\n        Iterator<Integer> it = numbers.iterator();\n        int max = it.next();\n        result.add(max);\n\n        while (it.hasNext()) {\n            int v = it.next();\n            if (v > max) max = v;\n            result.add(max);\n        }\n\n        return result;\n    }\n}",
