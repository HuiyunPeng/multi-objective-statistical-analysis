          "text": "#include <vector>\n#include <string>\nusing namespace std;\n\nvector<int> parse_nested_parens(string paren_string) {\n    vector<int> all_levels;\n    int level = 0, max_level = 0;\n\n    for (char chr : paren_string) {\n        if (chr == '(') {\n            ++level;\n            if (level > max_level) max_level = level;\n        } else if (chr == ')') {\n            --level;\n            if (level == 0) {\n                all_levels.push_back(max_level);\n                max_level = 0;\n            }\n        }\n    }\n\n    return all_levels;\n}",
