          "text": "#include <vector>\n#include <string>\nusing namespace std;\n\nvector<string> separate_paren_groups(string paren_string) {\n    vector<string> all_parens;\n    int level = 0;\n\n    for (char c : paren_string) {\n        if (c == '(') {\n            if (level == 0) all_parens.emplace_back();\n            ++level;\n            all_parens.back().push_back(c);\n        } else if (c == ')') {\n            all_parens.back().push_back(c);\n            --level;\n        }\n    }\n\n    return all_parens;\n}",
